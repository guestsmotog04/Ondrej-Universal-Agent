{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Agent": {
    "SettleDelayMs": 1500,
    "CoordinateMode": "DirectAutoNormalize",
    "MonitorIndex": null,
    "EnableContextReset": true,
    "StripHistoryImages": true
  },
  "Gemini": {
    "ApiKey": "",
    "Model": "gemini-3.5-flash",
    "MediaResolution": "High",
    "Temperature": 0.0,
    "TopP": 0.95,
    "TopK": 40,
    "CoordinateMaxOutputTokens": 256,
    "ThinkingBudget": 150,
    "ThinkingLevel": "minimal"
  }
}